# Optional for dev. Required in production. Use: openssl rand -hex 32
# AUTH_SECRET=your-secret

# Admin: admin@localhost / admin12345678 (crear con: bun run scripts/seed-admin.ts)

# Option A: Single user from env. Set both - registration will be disabled.
# AUTH_EMAIL=admin@example.com
# AUTH_PASSWORD=your-password

# Option B: Multi-user with registration. Leave AUTH_EMAIL unset. Users go in data/users.json
# (created automatically on first registration). No .env vars needed for users.

# Google AI (for image generation)
GOOGLE_GENERATIVE_AI_API_KEY=

# Local SQLite database for Prisma
DATABASE_URL="file:./dev.db"
