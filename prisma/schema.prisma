datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model ImageState {
  id                 String   @id @default(cuid())
  userId             String   @unique
  customImagesJson   String   @default("{}")
  galleryJson        String   @default("{}")
  backgroundPoolJson String   @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  type           String?
  promptTemplate String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  items          ProjectItem[]
  state          ProjectState?
}

model ProjectItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  subtitle    String?
  description String   @default("")
  tagline     String?
  extra       String?  // JSON for type-specific fields (virtue, period, etc.)
  imagePath   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectState {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customImagesJson   String   @default("{}")
  galleryJson        String   @default("{}")
  backgroundPoolJson String   @default("[]")
  templateJson       String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}


